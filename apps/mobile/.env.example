# VK ID (mobile)
# Должен совпадать с VK_MOBILE_REDIRECT_URI в API и redirect URI в настройках приложения VK
# VK_CLIENT_ID_IOS / VK_CLIENT_ID_ANDROID нужны в EAS при сборке: в натив добавляются схемы vk{id}://
VK_CLIENT_ID=
VK_CLIENT_ID_IOS=
VK_CLIENT_ID_ANDROID=
VK_MOBILE_REDIRECT_URI=gafus://auth/vk

# Tracer (проекты Гафус-ios и Гафус-android в apptracer.ru)
EXPO_PUBLIC_TRACER_APP_TOKEN_IOS=
EXPO_PUBLIC_TRACER_APP_TOKEN_ANDROID=
EXPO_PUBLIC_ENABLE_TRACER=true

# Та же процедура удаления аккаунта на сайте (опциональная ссылка в приложении)
EXPO_PUBLIC_ACCOUNT_DELETION_URL=https://gafus.ru/profile/delete-account
