{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "JAVA_HOME": "/opt/homebrew/opt/openjdk@17",
        "ANDROID_HOME": "/Users/asmtv1/Library/Android/sdk",
        "ORG_GRADLE_PROJECT_android.minSdkVersion": "24",
        "GRADLE_OPTS": "-Xmx4096m -XX:MaxMetaspaceSize=2048m"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "your@email.com",
        "ascAppId": "123456789"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services.json",
        "track": "internal"
      }
    }
  }
}