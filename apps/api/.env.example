# Apple IAP (верификация JWS на сервере; без .p8 для MVP)
APPLE_BUNDLE_ID=ru.gafus.app
# Числовой App ID из App Store Connect (обязателен для PRODUCTION)
APPLE_APP_APPLE_ID=
# SANDBOX | PRODUCTION
APPLE_ENVIRONMENT=SANDBOX
# JSON: [{ "productId": "...", "courseId": "..." }] или articleId
APPLE_IAP_PRODUCT_MAP_JSON=[]
