# Universal Links (iOS): Team ID из Apple Developer → Membership; без него AASA отдаёт пустой applinks
# APPLE_TEAM_ID=

# VK ID (web)
VK_CLIENT_ID=
VK_WEB_REDIRECT_URI=https://gafus.ru/api/auth/callback/vk-id

# Логи VK ID в консоль (при start:all + ngrok — добавь VK_ID_DEBUG=true для серверных логов)
# VK_ID_DEBUG=true

# Tracer: серверные ошибки (для dev-тестирования TRACER_SERVER_ENABLED=true)
# NEXT_PUBLIC_TRACER_APP_TOKEN=
# TRACER_SERVER_ENABLED=true

# Шифрование cookie pending_confirm после регистрации (в production обязателен)
# PENDING_CONFIRM_SECRET=
