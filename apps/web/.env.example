# Universal Links (iOS): Team ID из Apple Developer → Membership; без него AASA отдаёт пустой applinks
# APPLE_TEAM_ID=

# VK ID (web)
VK_CLIENT_ID=
VK_WEB_REDIRECT_URI=https://gafus.ru/api/auth/callback/vk-id

# Транзакционная почта (локально — свой SMTP или Mailpit; на проде — контейнер postfix)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_SECURE=false
# MAIL_FROM=noreply@gafus.ru
# MAIL_FROM_NAME=Гафус
