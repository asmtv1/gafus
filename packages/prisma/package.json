{
  "name": "@gafus/prisma",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "migrate": "prisma migrate deploy --schema=packages/prisma/schema.prisma",
    "seed": "node --loader ts-node/esm seed.ts",
    "prisma:generate": "prisma generate --schema=packages/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=packages/prisma/schema.prisma",
    "prisma:migrate:reset": "prisma migrate reset --force --skip-seed --schema=packages/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=packages/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "6.10.1",
    "bcrypt": "^6.0.0",
    "prisma": "6.10.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "ts-node": "^10.9.2",
    "prisma": "6.10.1"
  },
  "prisma": {
    "schema": "./schema.prisma"
  }
}
