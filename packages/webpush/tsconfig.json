{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "baseUrl": ".",
    "paths": {
      "@prisma": ["../prisma/src/index.ts"]
    },

    "outDir": "dist",
    "noEmit": false
  },
  "include": ["src"]
}
