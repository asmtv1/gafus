{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "CommonJS",
    "target": "ES2020",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/shared/prisma": ["../shared/prisma/index.ts"],
      "@/shared/*": ["../shared/*"]
    }
  },
  "include": ["bull-board.ts", "src/lib/queues/**/*.ts"]
}
