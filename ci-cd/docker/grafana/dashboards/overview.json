        {
          "expr": "pg_up",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Офлайн", "color": "red" }, "1": { "text": "Онлайн", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{"value": null, "color": "red"}, {"value": 1, "color": "green"}] }
        }
      },
      "options": { "textMode": "value_and_name", "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 8,
      "title": "CPU (%)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 9,
      "title": "RAM (%)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 10,
      "title": "Диск свободно (%)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "(node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100",
          "legendFormat": "Disk free",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 11,
      "title": "Push queue (jobs)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "bullmq_job_count{queue=\"push\",state=\"waiting\"}",
          "legendFormat": "push - waiting",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        },
        {
          "expr": "bullmq_job_count{queue=\"push\",state=\"active\"}",
          "legendFormat": "push - active",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        },
        {
          "expr": "bullmq_job_count{queue=\"push\",state=\"completed\"}",
          "legendFormat": "push - completed",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        }
      ]
    }
